{
  "rules": {
    ".read": "auth != null",
    ".write": "auth != null",
    
    "players": {
      ".indexOn": ["mobile", "name", "position"]
    },
    
    "tournaments": {
      ".indexOn": ["name", "date", "createdAt"]
    },
    
    "tournament_registrations": {
      "$tournamentId": {
        ".indexOn": ["mobile", "name", "registeredAt"]
      }
    },
    
    "tournament_registrations_unique": {
      ".indexOn": [".value"]
    }
  }
}
